# Copy to .env and fill in values (all optional)

# Free LLM via Groq (recommended for reviewers): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Or OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# openai | groq | auto (default auto prefers Groq if set)
LLM_PROVIDER=auto

RESUME_DIR=sample_resumes
JD_PATH=JD/job_description.txt
OUTPUT_DIR=outputs
